# ── HackaroundCIA environment ───────────────────────────────────────────────
# Copy to .env.local and fill in. The human provisions Supabase + Groq manually;
# this app never scaffolds provisioning and reads everything from env.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used for privileged server actions (e.g. deleting a storage
# object on document confirmation). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Groq (LLM — extraction only)
GROQ_API_KEY=
# Verified 2026-06-26: current + multimodal (text + image). Groq's recommended
# migration target now that qwen/qwen3-32b is deprecating.
GROQ_MODEL=qwen/qwen3.6-27b

# Public site URL — used for magic-link email redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Upload / cost caps (optional overrides; defaults live in lib/config.ts)
# MAX_FILES_PER_BATCH=5
# MAX_FILE_MB=8
